          "when": "view =~ /^ck3\\.(overview|locCoverage|overrides)$/",
          "group": "navigation@1"
        },
        {
          "command": "ck3.refreshViews",
          "when": "view =~ /^ck3\\./",
          "group": "navigation"
        },
        {
          "command": "ck3.showEventGraph",
          "when": "view == ck3.overview",
          "group": "navigation"
        },
        {
          "command": "ck3.createTranslation",
          "when": "view == ck3.locCoverage",
          "group": "navigation"
