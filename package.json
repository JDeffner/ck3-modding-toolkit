{
  "name": "ck3-modding-toolkit",
  "displayName": "CK3 Modding Toolkit",
  "description": "Crusader Kings III modding toolkit: completion, go-to-definition, hover docs, ck3-tiger diagnostics, inline localization, event graph and GUI preview.",
  "version": "0.1.2",
  "publisher": "JDeffner",
  "author": {
    "name": "Joël Deffner"
  },
  "license": "GPL-3.0-or-later",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "paradox",
        "aliases": [
          "CK3 Script",
          "Paradox Script"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./media/fileicons/paradox-light.svg",
          "dark": "./media/fileicons/paradox-dark.svg"
        }
      },
      {
        "id": "paradox-loc",
        "aliases": [
          "CK3 Localization"
        ],
        "configuration": "./loc-language-configuration.json",
        "icon": {
          "light": "./media/fileicons/paradox-loc-light.svg",
          "dark": "./media/fileicons/paradox-loc-dark.svg"
        }
      },
      {
        "id": "paradox-gui",
        "aliases": [
          "CK3 GUI",
          "PdxGui"
        ],
        "configuration": "./gui-language-configuration.json",
        "icon": {
          "light": "./media/fileicons/paradox-gui-light.svg",
          "dark": "./media/fileicons/paradox-gui-dark.svg"
        }
      },
      {
        "id": "paradox-info",
        "aliases": [
          "CK3 Format Docs"
        ],
        "filenamePatterns": [
          "**/_*.info"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./media/fileicons/paradox-info-light.svg",
          "dark": "./media/fileicons/paradox-info-dark.svg"
        }
      },
      {
        "id": "paradox-mod",
        "aliases": [
          "CK3 Mod Descriptor"
        ],
        "filenames": [
          "descriptor.mod"
        ],
        "filenamePatterns": [
          "**/Paradox Interactive/*/mod/*.mod"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./media/fileicons/paradox-mod-light.svg",
          "dark": "./media/fileicons/paradox-mod-dark.svg"
        }
      },
      {
        "id": "dds",
        "aliases": [
          "DDS Texture"
        ],
        "extensions": [
          ".dds"
        ],
        "icon": {
          "light": "./media/fileicons/dds-light.svg",
          "dark": "./media/fileicons/dds-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "paradox",
        "scopeName": "source.paradox",
        "path": "./syntaxes/paradox.tmLanguage.json"
      },
      {
        "language": "paradox-loc",
        "scopeName": "source.paradox-loc",
        "path": "./syntaxes/paradox-loc.tmLanguage.json"
      },
      {
        "language": "paradox-gui",
        "scopeName": "source.paradox-gui",
        "path": "./syntaxes/paradox-gui.tmLanguage.json"
      },
      {
        "language": "paradox-info",
        "scopeName": "source.paradox-info",
        "path": "./syntaxes/paradox-info.tmLanguage.json"
      },
      {
        "language": "paradox-mod",
        "scopeName": "source.paradox-mod",
        "path": "./syntaxes/paradox-mod.tmLanguage.json"
      },
      {
        "scopeName": "source.paradox-datafunction",
        "path": "./syntaxes/paradox-datafunction.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[paradox]": {
        "editor.wordBasedSuggestions": "off"
      },
      "[paradox-loc]": {
        "editor.wordBasedSuggestions": "off",
        "editor.quickSuggestions": {
          "strings": "on"
        }
      },
      "[paradox-gui]": {
        "editor.wordBasedSuggestions": "off",
        "editor.quickSuggestions": {
          "strings": "on"
        }
      },
      "[paradox-info]": {
        "editor.wordBasedSuggestions": "off"
      },
      "[paradox-mod]": {
        "editor.wordBasedSuggestions": "off"
      }
    },
    "commands": [
      {
        "command": "ck3.reloadScriptDocs",
        "category": "CK3",
        "title": "Reload Game Data (script_docs)"
      },
      {
        "command": "ck3.dumpIndexStats",
        "category": "CK3",
        "title": "Show Index Statistics"
      },
      {
        "command": "ck3.runTiger",
        "category": "CK3 Tiger",
        "title": "Run Validation"
      },
      {
        "command": "ck3.editLocalization",
        "category": "CK3 Localization",
        "title": "Edit Key at Cursor"
      },
      {
        "command": "ck3.openLocalizationSideBySide",
        "category": "CK3 Localization",
        "title": "Open Side by Side"
      },
      {
        "command": "ck3.jumpToScriptReference",
        "category": "CK3 Localization",
        "title": "Go to Script Usage"
      },
      {
        "command": "ck3.createTranslation",
        "category": "CK3 Localization",
        "title": "Add Language (scaffold files)",
        "icon": "$(new-file)"
      },
      {
        "command": "ck3.createTranslationMod",
        "category": "CK3 Localization",
        "title": "New Translation Mod (translate another mod)"
      },
      {
        "command": "ck3.pickFocusMod",
        "category": "CK3",
        "title": "Pick Focus Mod (for the sidebar views)",
        "icon": "$(folder-library)"
      },
      {
        "command": "ck3.excludeMods",
        "category": "CK3",
        "title": "Exclude Workspace Mods from Indexing",
        "icon": "$(eye-closed)"
      },
      {
        "command": "ck3.setup",
        "category": "CK3",
        "title": "Run Setup & Health Check"
      },
      {
        "command": "ck3.downloadTiger",
        "category": "CK3 Tiger",
        "title": "Download or Update Binary"
      },
      {
        "command": "ck3.openInfoDocs",
        "category": "CK3",
        "title": "Open Format Docs (.info) for This File",
        "icon": "$(book)"
      },
      {
        "command": "ck3.openVanillaExamples",
        "category": "CK3",
        "title": "Open Vanilla Examples",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ck3.refreshViews",
        "category": "CK3",
        "title": "Refresh Views",
        "icon": "$(refresh)"
      },
      {
        "command": "ck3.showEventGraph",
        "category": "CK3",
        "title": "Show Event Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "ck3.showDependencies",
        "category": "CK3",
        "title": "Show Dependencies of Definition at Cursor",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "ck3.showGuiTree",
        "category": "CK3",
        "title": "Show GUI Widget Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "ck3.guiTreeToggleParents",
        "category": "CK3",
        "title": "GUI Tree: Toggle Ancestors / Subtree Focus",
        "enablement": "activeWebviewPanelId == ck3.guiTree"
      },
      {
        "command": "ck3.showGuiPreview",
        "category": "CK3",
        "title": "Preview GUI Layout",
        "icon": "$(preview)"
      },
      {
        "command": "ck3.modReport",
        "category": "CK3",
        "title": "Show Mod Report"
      },
      {
        "command": "ck3.tigerCreateBaseline",
        "category": "CK3 Tiger",
        "title": "Create Baseline (snapshot current problems)"
      },
      {
        "command": "ck3.tigerToggleBaseline",
        "category": "CK3 Tiger",
        "title": "Toggle New-Problems-Only Filter"
      },
      {
        "command": "ck3.tigerUnused",
        "category": "CK3 Tiger",
        "title": "Find Unused Definitions (--unused)"
      },
      {
        "command": "ck3.tigerGenerateConf",
        "category": "CK3 Tiger",
        "title": "Generate ck3-tiger.conf"
      },
      {
        "command": "ck3.watchErrorLog",
        "category": "CK3",
        "title": "Toggle error.log Watcher"
      },
      {
        "command": "ck3.launchGame",
        "category": "CK3",
        "title": "Launch CK3 (debug mode)"
      },
      {
        "command": "ck3.translateNext",
        "category": "CK3 Localization",
        "title": "Translate Missing Keys (one by one)"
      },
      {
        "command": "ck3.newContent",
        "category": "CK3",
        "title": "New Content (event, decision, …)"
      },
      {
        "command": "ck3.convertToDds",
        "category": "CK3",
        "title": "Convert Image to DDS",
        "icon": "$(file-media)"
      },
      {
        "command": "ck3.imageGuidelines",
        "category": "CK3",
        "title": "Show Image Guidelines (sizes & formats)",
        "icon": "$(book)"
      },
      {
        "command": "ck3.addLocalizationFromView",
        "category": "CK3 Localization",
        "title": "Add Localization…",
        "icon": "$(add)"
      },
      {
        "command": "ck3.tutorial",
        "category": "CK3",
        "title": "Open Tutorial (learn CK3 modding)",
        "icon": "$(mortar-board)"
      },
      {
        "command": "ck3.createDescriptor",
        "category": "CK3",
        "title": "Create descriptor.mod"
      }
    ],
    "customEditors": [
      {
        "viewType": "ck3.ddsPreview",
        "displayName": "DDS Preview",
        "selector": [
          {
            "filenamePattern": "*.dds"
          }
        ],
        "priority": "default"
      }
    ],
    "walkthroughs": [
      {
        "id": "ck3.gettingStarted",
        "title": "Get started with the CK3 Modding Toolkit",
        "description": "Configure the extension and try its features on your mod.",
        "steps": [
          {
            "id": "ck3.step.setup",
            "title": "Run automatic setup",
            "description": "Detects your CK3 install via Steam, checks the logs folder and offers to download the ck3-tiger validator.\n[Run Setup & Health Check](command:ck3.setup)",
            "media": {
              "markdown": "media/walkthrough/setup.md"
            },
            "completionEvents": [
              "onCommand:ck3.setup"
            ]
          },
          {
            "id": "ck3.step.mod",
            "title": "Open your mod folder",
            "description": "Open the folder containing common/, events/ and localization/ as your workspace. The extension indexes it and watches for changes.\n[Open Folder](command:workbench.action.files.openFolder)",
            "media": {
              "markdown": "media/walkthrough/mod.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.files.openFolder"
            ]
          },
          {
            "id": "ck3.step.scriptdocs",
            "title": "Generate script_docs (recommended)",
            "description": "The bundled wiki data works out of the box; script_docs matches your exact game patch and adds modifiers.\n[Reload Game Data (script_docs)](command:ck3.reloadScriptDocs)",
            "media": {
              "markdown": "media/walkthrough/scriptdocs.md"
            },
            "completionEvents": [
              "onCommand:ck3.reloadScriptDocs"
            ]
          },
          {
            "id": "ck3.step.tiger",
            "title": "Enable tiger diagnostics",
            "description": "ck3-tiger validates your mod on every save and shows problems as squiggles.\n[Download ck3-tiger](command:ck3.downloadTiger)",
            "media": {
              "markdown": "media/walkthrough/tiger.md"
            },
            "completionEvents": [
              "onCommand:ck3.downloadTiger",
              "onSettingChanged:ck3.tigerPath"
            ]
          },
          {
            "id": "ck3.step.explore",
            "title": "Try it",
            "description": "Open an event file: hover an effect, F12 a scripted effect, check the inline localization.\n[Show Index Statistics](command:ck3.dumpIndexStats)",
            "media": {
              "markdown": "media/walkthrough/explore.md"
            },
            "completionEvents": [
              "onCommand:ck3.dumpIndexStats"
            ]
          },
          {
            "id": "ck3.step.overview",
            "title": "Explore the CK3 view",
            "description": "The CK3 icon in the Activity Bar opens the mod overview: content inventory, problems, localization coverage, overrides and the event graph.\n[Show Event Graph](command:ck3.showEventGraph)\n[Show Mod Report](command:ck3.modReport)",
            "media": {
              "markdown": "media/walkthrough/explore.md"
            },
            "completionEvents": [
              "onCommand:ck3.showEventGraph",
              "onCommand:ck3.modReport"
            ]
          }
        ]
      }
    ],
    "configuration": [
      {
        "title": "Setup",
        "order": 1,
        "properties": {
          "ck3.gamePath": {
            "type": "string",
            "default": "",
            "order": 1,
            "scope": "machine-overridable",
            "markdownDescription": "Path to the CK3 game data folder, e.g. `.../steamapps/common/Crusader Kings III/game`. Powers completion, hover and go-to-definition on vanilla content.\n\n**Easiest:** leave empty and run `CK3: Run Setup & Health Check` — it finds the game via Steam and fills this in. Opening the game folder as an extra workspace folder also works."
          },
          "ck3.logsPath": {
            "type": "string",
            "default": "",
            "order": 2,
            "scope": "machine-overridable",
            "markdownDescription": "Folder containing the `script_docs` log files (`triggers.log`, `effects.log`, `event_targets.log`, `modifiers.log`). Leave empty to auto-detect `Documents/Paradox Interactive/Crusader Kings III/logs`.\n\nThe logs upgrade the bundled wiki data to your exact game version: launch CK3 with `-debug_mode`, run `script_docs` in the console (\\`), then run `CK3: Reload Game Data (script_docs)`."
          },
          "ck3.tigerPath": {
            "type": "string",
            "default": "",
            "order": 3,
            "scope": "machine-overridable",
            "markdownDescription": "Path to your own `ck3-tiger` binary. Leave empty to use the copy installed by `CK3 Tiger: Download or Update Binary` (also offered during Setup)."
          }
        }
      },
      {
        "title": "Mods",
        "order": 2,
        "properties": {
          "ck3.modPath": {
            "type": "string",
            "default": "",
            "order": 1,
            "scope": "machine-overridable",
            "markdownDescription": "**Leave this empty** unless your mod folder is not part of the workspace. Every workspace folder that is a CK3 mod is detected and fully indexed automatically. Features follow the file you are editing, and the sidebar views follow it too (or a mod you pin via `CK3: Pick Focus Mod`)."
          },
          "ck3.parentMods": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "order": 2,
            "scope": "machine-overridable",
            "markdownDescription": "Dependency mods your mod builds on, for submods and compatibility patches. Absolute paths in load order, base first.\n\nParents are read-only context: their definitions resolve in completion, hover and navigation, but they are not validated or edited. Do **not** list mods you are editing — open those as workspace folders instead (*File → Add Folder to Workspace*) and they are picked up automatically.\n\nShareable per-mod alternative: `<mod>/.ck3modding/playset.json` with `{ \"parents\": [\"path/to/parent\"] }`."
          },
          "ck3.excludedMods": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "order": 3,
            "scope": "machine-overridable",
            "markdownDescription": "Workspace mod folders to skip entirely (absolute paths). Excluded mods are not indexed: no completion, hover, navigation, diagnostics or views. Useful when the workspace contains mods you are not currently working on.\n\nEasiest via `CK3: Exclude Workspace Mods from Indexing` (also in the sidebar Tools view), which shows a checklist of the detected mods."
          },
          "ck3.locLanguage": {
            "type": "string",
            "default": "english",
            "order": 4,
            "markdownDescription": "Localization language to index and display (matches `l_<language>` yml files), e.g. `english`, `french`, `german`."
          }
        }
      },
      {
        "title": "Validation",
        "order": 3,
        "properties": {
          "ck3.tigerRunOn": {
            "type": "string",
            "enum": [
              "save",
              "manual"
            ],
            "enumDescriptions": [
              "Run on every save of a mod script file (debounced).",
              "Run only via the 'CK3 Tiger: Run Validation' command."
            ],
            "default": "manual",
            "order": 1,
            "markdownDescription": "When the ck3-tiger validator runs."
          },
          "ck3.diagnostics.ignore": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "order": 2,
            "markdownDescription": "Diagnostic codes to suppress everywhere. Applies to the extension's own structural/localization codes (e.g. `missing-bom`, `unknown-event`) and to ck3-tiger report keys (e.g. `unknown-field`).\n\nFor single lines, an inline `# ck3m:ignore <code>` comment does the same."
          },
          "ck3.diagnostics.ignorePatterns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "order": 3,
            "markdownDescription": "Glob patterns matched against workspace-relative file paths; all diagnostics (ours and tiger's) in matching files are suppressed. Supports `*` (within a path segment) and `**` (across segments), e.g. `common/**/vendor/*.txt` or `*.generated.txt`."
          },
          "ck3.diagnostics.vanilla": {
            "type": "boolean",
            "default": false,
            "order": 4,
            "markdownDescription": "Diagnose files under `ck3.gamePath` (vanilla game content). Off by default: the extension only ever diagnoses your mod's files."
          }
        }
      },
      {
        "title": "Editor",
        "order": 4,
        "properties": {
          "ck3.scopeInlayHints": {
            "type": "boolean",
            "default": false,
            "order": 1,
            "markdownDescription": "Show the inferred scope (e.g. `character`) after scope-changing block openers like `every_vassal = {`. Best-effort inference; display only."
          },
          "ck3.enableForWorkspace": {
            "type": "boolean",
            "default": true,
            "order": 2,
            "markdownDescription": "Escape hatch: set to false to stop this workspace's txt/yml files from being switched to the CK3 language modes."
          },
          "ck3.trace.server": {
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "order": 3,
            "markdownDescription": "Trace the communication between VS Code and the CK3 language server (for debugging / bug reports)."
          }
        }
      }
    ],
