      ],
      "view/item/context": [
        {
          "command": "ck3.addLocalizationFromView",
          "when": "view == ck3.locCoverage && viewItem == ck3.locMissing",
          "group": "inline"
        },
        {
          "command": "ck3.addLocalizationFromView",
          "when": "view == ck3.locCoverage && viewItem =~ /^ck3\\.loc/",
          "group": "1_edit"
        }
      ],
      "editor/title": [
        {
          "command": "ck3.showGuiTree",
          "when": "resourceExtname == .gui && ck3.isCk3Workspace",
          "group": "navigation"
        },
        {
          "command": "ck3.showGuiPreview",
          "when": "resourceExtname == .gui && ck3.isCk3Workspace",
          "group": "navigation"
        },
        {
          "command": "ck3.showEventGraph",
          "when": "resourceExtname == .txt && resourcePath =~ /events|on_action|decisions/ && ck3.isCk3Workspace",
          "group": "navigation"
        },
        {
          "command": "ck3.openInfoDocs",
          "when": "ck3.hasInfoDoc && (resourceLangId == paradox || resourceLangId == paradox-gui || resourceLangId == paradox-loc)",
          "group": "navigation"
        },
        {
          "command": "ck3.openVanillaExamples",
          "when": "resourceLangId == paradox-info",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "ck3.convertToDds",
          "when": "resourceExtname =~ /\\.(png|jpe?g|webp)$/i",
          "group": "7_modification"
        }
      ]
    },
    "snippets": [
      {
        "language": "paradox",
        "path": "./snippets/paradox.json"
      }
    ],
    "keybindings": [
      {
        "command": "ck3.editLocalization",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus && (editorLangId == paradox || editorLangId == paradox-loc)"
      },
      {
        "command": "ck3.showGuiPreview",
        "key": "ctrl+alt+p",
        "when": "editorTextFocus && editorLangId == paradox-gui"
      },
      {
        "command": "ck3.showGuiTree",
        "key": "ctrl+alt+w",
        "when": "editorTextFocus && editorLangId == paradox-gui"
      },
      {
        "command": "ck3.guiTreeToggleParents",
        "key": "ctrl+alt+h",
        "when": "activeWebviewPanelId == ck3.guiTree"
      },
      {
        "command": "ck3.showEventGraph",
        "key": "ctrl+alt+g",
        "when": "editorTextFocus && editorLangId == paradox"
      },
      {
        "command": "ck3.showDependencies",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus && editorLangId == paradox"
      },
      {
        "command": "ck3.runTiger",
        "key": "ctrl+alt+v",
        "when": "editorLangId == paradox || editorLangId == paradox-loc || editorLangId == paradox-gui"
      },
      {
        "command": "ck3.openLocalizationSideBySide",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus && (editorLangId == paradox || editorLangId == paradox-loc)"
      },
      {
        "command": "ck3.jumpToScriptReference",
        "key": "ctrl+alt+j",
        "when": "editorTextFocus && editorLangId == paradox-loc"
      },
      {
        "command": "ck3.openInfoDocs",
        "key": "ctrl+alt+o",
        "when": "editorTextFocus && ck3.hasInfoDoc"
      }
    ]
  },
  "scripts": {
    "compile": "npm run compile:client && npm run compile:server",
    "watch": "esbuild client/src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --allow-missing-repository --no-dependencies",
    "testp": "node scripts/package-preview.mjs",
    "compile:client": "esbuild client/src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "compile:server": "esbuild server/src/server.ts --bundle --outfile=dist/server.js --format=cjs --platform=node --target=node18",
    "watch:server": "esbuild server/src/server.ts --bundle --outfile=dist/server.js --format=cjs --platform=node --target=node18 --watch"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "vscode-jsonrpc": "^9.0.1"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "icon": "media/icon.png",
  "keywords": [
    "ck3",
    "crusader kings",
    "paradox",
    "modding",
    "language server",
    "ck3-tiger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JDeffner/ck3-modding-toolkit.git"
  }
}
