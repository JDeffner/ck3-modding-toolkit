{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CK3 Localization",
  "scopeName": "source.paradox-loc",
  "patterns": [
    { "include": "#comment" },
    { "include": "#language-header" },
    { "include": "#entry" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.paradox-loc",
      "match": "#.*$"
    },
    "language-header": {
      "name": "keyword.control.language.paradox-loc",
      "match": "^\\s*l_[a-z_]+:\\s*$"
    },
    "entry": {
      "begin": "^\\s*([A-Za-z0-9_.\\-']+)(:)(\\d*)",
      "beginCaptures": {
        "1": { "name": "entity.name.tag.loc-key.paradox-loc" },
        "2": { "name": "punctuation.separator.key-value.paradox-loc" },
        "3": { "name": "constant.numeric.version.paradox-loc" }
      },
      "end": "$",
      "patterns": [
        {
          "name": "string.quoted.double.paradox-loc",
          "begin": "\"",
          "end": "\"(?=[^\"]*$)",
          "patterns": [
            { "name": "constant.character.escape.paradox-loc", "match": "\\\\." },
            { "name": "variable.other.substitution.paradox-loc", "match": "\\$[A-Za-z0-9_.|\\-]+\\$" },
            { "include": "source.paradox-datafunction" },
            { "name": "constant.other.formatting.paradox-loc", "match": "#[!A-Za-z_;]*" },
            { "name": "constant.other.icon.paradox-loc", "match": "@[A-Za-z0-9_]+!" }
          ]
        }
      ]
    }
  }
}
