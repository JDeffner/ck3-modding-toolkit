{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CK3 Script",
  "scopeName": "source.paradox",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#macro-param" },
    { "include": "#inline-math" },
    { "include": "#script-constant" },
    { "include": "#date" },
    { "include": "#event-id" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#color-model" },
    { "include": "#asset-ref" },
    { "include": "#saved-scope" },
    { "include": "#scope-ref" },
    { "include": "#iterator" },
    { "include": "#control" },
    { "include": "#block-key" },
    { "include": "#loc-property" },
    { "include": "#operator" },
    { "include": "#braces" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.paradox",
      "match": "#.*$"
    },
    "string": {
      "name": "string.quoted.double.paradox",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.paradox", "match": "\\\\." },
        { "name": "variable.other.substitution.paradox", "match": "\\$[A-Za-z0-9_.|\\-]+\\$" },
        { "name": "support.function.databinding.paradox", "match": "\\[[^\\]]*\\]" },
        { "name": "constant.other.formatting.paradox", "match": "#[!A-Za-z_;]+" }
      ]
    },
    "macro-param": {
      "comment": "$PARAM$ substitution in scripted effects/triggers, incl. $NAME|default$",
      "name": "variable.parameter.macro.paradox",
      "match": "\\$[A-Za-z0-9_.|\\-]+\\$"
    },
    "script-constant": {
      "comment": "@name script constants (@pos_compat_low = 0.5 and their uses)",
      "name": "variable.other.constant.script.paradox",
      "match": "@[A-Za-z_][A-Za-z0-9_]*\\b"
    },
    "inline-math": {
      "comment": "@[ ... ] inline math over script constants",
      "name": "meta.inline-math.paradox",
      "begin": "@\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.section.math.begin.paradox" } },
      "endCaptures": { "0": { "name": "punctuation.section.math.end.paradox" } },
      "patterns": [
        { "name": "constant.numeric.paradox", "match": "-?\\d+(\\.\\d+)?" },
        { "name": "keyword.operator.arithmetic.paradox", "match": "[-+*/%()]" },
        { "name": "variable.other.constant.script.paradox", "match": "[A-Za-z_][A-Za-z0-9_]*" }
      ]
    },
    "date": {
      "comment": "Y.M.D with optional hour component (Y.M.D.H) — title history uses 4-part dates",
      "name": "constant.numeric.date.paradox",
      "match": "\\b\\d{1,4}\\.\\d{1,2}\\.\\d{1,2}(?:\\.\\d{1,2})?\\b"
    },
    "event-id": {
      "comment": "Event IDs: namespace.NNNN — visually distinct so event chains stand out",
      "name": "entity.name.function.event-id.paradox",
      "match": "\\b[A-Za-z][A-Za-z0-9_\\-]*\\.\\d+\\b(?!\\.\\d)"
    },
    "number": {
      "name": "constant.numeric.paradox",
      "match": "(?<![\\w.])-?\\d+(\\.\\d+)?(?![\\w.])"
    },
    "constant": {
      "name": "constant.language.paradox",
      "match": "\\b(yes|no|none)\\b"
    },
    "color-model": {
      "comment": "color = rgb { 255 0 0 } / hsv { 0.5 1 1 } / hsv360 { 180 100 100 }: the model tag before the block",
      "name": "support.type.color-model.paradox",
      "match": "\\b(rgb|hsv360|hsv)\\b(?=\\s*\\{)"
    },
    "asset-ref": {
      "comment": "Art/sound reference values (icon = X.dds, animation = happiness, entity = …): the value reads as an unquoted string so asset names aren't invisible",
      "match": "\\b(icon|texture|entity|animation|scripted_animation|camera|soundeffect|clicksound|environment|ambience|reference)\\s*(=)\\s*([A-Za-z0-9_][A-Za-z0-9_.\\\\/\\-]*)(?![A-Za-z0-9_:])",
      "captures": {
        "1": { "name": "entity.name.tag.block.paradox" },
        "2": { "name": "keyword.operator.comparison.paradox" },
        "3": { "name": "string.unquoted.reference.paradox" }
      }
    },
    "saved-scope": {
      "comment": "scope:x / var:x / flag:x references — the mod's own runtime state",
      "name": "variable.other.saved-scope.paradox",
      "match": "\\b(scope|var|local_var|global_var|flag|event_target|define|list|title|character|province|culture|faith|dynasty|house|religion|trait|vassal_contract|struggle|epidemic):[A-Za-z0-9_.\\-]+\\b"
    },
    "scope-ref": {
      "comment": "Built-in scope navigation (root/this/prev/from and common scope-changer links). ROOT/THIS/PREV/FROM: vanilla uses the uppercase forms too (portrait blocks etc.)",
      "name": "variable.language.scope.paradox",
      "match": "\\b(root|ROOT|this|THIS|prev(prev)*|PREV(PREV)*|from(from)*|FROM(FROM)*|liege|holder|mother|father|primary_spouse|primary_title|primary_heir|player_heir|capital_province|capital_county|capital_barony|top_liege|court_owner|employer|county|duchy|kingdom|empire|barony|province|location|culture_head|faith|culture|religion|dynasty|house|betrothed|host|killer|imprisoner|realm_priest|designated_heir|ghw_beneficiary|involved_activity|activity|activity_host|story_owner|secret_owner|secret_target|scheme_owner|scheme_target|title_province|county_controller|barony_controller|province_owner|current_travel_plan|court_position_employer|accolade_owner)\\b(?=\\s*[.=]|\\s*$|\\s)"
    },
    "iterator": {
      "comment": "List iterators: any_ (trigger), every_/random_/ordered_ (effects)",
      "name": "keyword.operator.iterator.paradox",
      "match": "\\b(any|every|random|ordered)_[a-z0-9_]+\\b"
    },
    "control": {
      "name": "keyword.control.paradox",
      "match": "\\b(if|else_if|else|while|switch|trigger_if|trigger_else_if|trigger_else|AND|OR|NOT|NOR|NAND|and|or|not|nor|nand|limit|alternative_limit|filter|namespace|first_valid|random_valid|triggered_desc|hidden_effect|hidden_trigger|show_as_tooltip|custom_description|custom_tooltip|calc_true_if|exists|always|save_scope_as|save_scope_value_as|save_temporary_scope_as|save_temporary_scope_value_as|clear_saved_scope|add_to_list|add_to_temporary_list|remove_from_list|is_in_list|random_list|duel|send_interface_toast|send_interface_message|trigger_event)\\b"
    },
    "block-key": {
      "comment": "Structural block keys that shape events/decisions/interactions",
      "name": "entity.name.tag.block.paradox",
      "match": "\\b(type|hidden|trigger|immediate|effect|option|after|potential|allow|can_pick|ai_chance|ai_will_do|ai_potential|is_shown|is_valid|is_valid_showing_failures_only|on_accept|on_decline|on_send|on_start|on_end|on_complete|on_invalidated|modifier|compare_modifier|opinion_modifier|weight|weight_multiplier|desc|title|theme|override_background|left_portrait|right_portrait|center_portrait|lower_left_portrait|lower_center_portrait|lower_right_portrait|animation|scaled_by|min|max|value|add|multiply|divide|subtract|factor|base|days|weeks|months|years|duration|target|order_by|position|chance|cost|gold|piety|prestige)\\s*(?=\\??=)"
    },
    "loc-property": {
      "comment": "Any other key on the left of = reads as a property; keeps key/value texture visible",
      "name": "variable.other.property.paradox",
      "match": "\\b[A-Za-z_][A-Za-z0-9_.\\-]*\\s*(?=\\??=)"
    },
    "operator": {
      "name": "keyword.operator.comparison.paradox",
      "match": "(\\?=|>=|<=|!=|==|=|<|>)"
    },
    "braces": {
      "patterns": [
        { "name": "punctuation.section.block.begin.paradox", "match": "\\{" },
        { "name": "punctuation.section.block.end.paradox", "match": "\\}" },
        { "name": "punctuation.section.brackets.paradox", "match": "[\\[\\]]" }
      ]
    }
  }
}
