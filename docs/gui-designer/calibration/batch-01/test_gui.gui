# CALIBRATION BATCH 01 — replaces game/gui/debug/test_gui.gui (vanilla backup: test_gui.gui.vanilla.bak)
# Spawn:   gui.CreateWidget gui/debug/test_gui.gui test_window
# Despawn: gui.clearwidgets test_window
# Every marker is a flat opaque color on gfx/interface/colors/white.dds; see expectations.md for the color legend.
window = {
	name = "test_window"
	parentanchor = center
	size = { 1000 800 }
	layer = top
	filter_mouse = all
	alwaystransparent = no

	using = Window_Background
	using = Window_Decoration
	using = Window_Movable

	vbox = {
		using = Window_Margins

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				raw_text = "Calibration batch 01"
			}

			blockoverride "button_close"
			{
				onclick = "[ExecuteConsoleCommand( 'gui.clearwidgets test_window')]"
			}
		}

		# The canvas: black 940x650 rectangle, doubles as the ruler (940 units wide).
		# All case positions are relative to its top-left corner.
		widget = {
			size = { 940 650 }
			background = {
				texture = "gfx/interface/colors/white.dds"
				color = { 0 0 0 1 }
			}

			# ---- CASE A: ruler bars (linear scale check) ----
			icon = {
				position = { 20 12 }
				size = { 200 12 }
				texture = "gfx/interface/colors/white.dds"
				color = { 1 1 1 1 }
			}
			icon = {
				position = { 240 12 }
				size = { 100 12 }
				texture = "gfx/interface/colors/white.dds"
				color = { 1 0 1 1 }
			}
			icon = {
				position = { 360 12 }
				size = { 50 12 }
				texture = "gfx/interface/colors/white.dds"
				color = { 0 1 1 1 }
			}
			text_single = {
				position = { 430 8 }
				raw_text = "A: 200 / 100 / 50"
			}

			# ---- CASE B: parentanchor matrix (no widgetanchor, no position) ----
			# Container 300x200 at (20,60); nine 20x20 markers, one per anchor.
			widget = {
				position = { 20 60 }
				size = { 300 200 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.2 0.2 0.2 1 }
				}

				icon = {
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 1 1 1 }
				}
				icon = {
					parentanchor = top|hcenter
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 0 0 1 }
				}
				icon = {
					parentanchor = top|right
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 0.5 0 1 }
				}
				icon = {
					parentanchor = vcenter|left
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 1 0 1 }
				}
				icon = {
					parentanchor = center
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 1 0 1 }
				}
				icon = {
					parentanchor = vcenter|right
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 1 1 1 }
				}
				icon = {
					parentanchor = bottom|left
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 0 1 1 }
				}
				icon = {
					parentanchor = bottom|hcenter
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 0 1 1 }
				}
				icon = {
					parentanchor = bottom|right
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0.5 0 1 1 }
				}
			}
			text_single = {
				position = { 20 42 }
				raw_text = "B: parentanchor"
			}

			# ---- CASE C: widgetanchor vs default ----
			# Container 300x200 at (360,60); 40x40 markers.
			# Explicit-widgetanchor marker drawn FIRST so the implicit one covers it if they coincide.
			widget = {
				position = { 360 60 }
				size = { 300 200 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.1 0.1 0.3 1 }
				}

				icon = {
					parentanchor = center
					widgetanchor = center
					size = { 40 40 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 1 0 1 }
				}
				icon = {
					parentanchor = center
					size = { 40 40 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 0 0 1 }
				}
				icon = {
					parentanchor = bottom|right
					widgetanchor = bottom|right
					size = { 40 40 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 1 1 1 }
				}
				icon = {
					parentanchor = bottom|right
					size = { 40 40 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 1 0 1 }
				}
			}
			text_single = {
				position = { 360 42 }
				raw_text = "C: widgetanchor"
			}

			# ---- CASE D: position offsets combined with anchors + clipping probe ----
			# Container 220x200 at (700,60); 20x20 markers.
			widget = {
				position = { 700 60 }
				size = { 220 200 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.1 0.25 0.1 1 }
				}

				icon = {
					position = { 30 30 }
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 0 0 1 }
				}
				icon = {
					parentanchor = bottom|right
					widgetanchor = bottom|right
					position = { -30 -30 }
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 1 0 1 }
				}
				icon = {
					parentanchor = bottom|right
					widgetanchor = bottom|right
					position = { 30 30 }
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 1 1 0 1 }
				}
				icon = {
					parentanchor = center
					position = { 40 0 }
					size = { 20 20 }
					texture = "gfx/interface/colors/white.dds"
					color = { 0 1 1 1 }
				}
			}
			text_single = {
				position = { 700 42 }
				raw_text = "D: position"
			}

			# ---- CASE E: hbox metrics (hug, cross-axis alignment, spacing, margin) ----
			# Each hbox sits inside a 180x120 gray widget (also measures how a box
			# places itself inside a plain fixed-size widget).
			# Children everywhere: red 60x40, green 40x60, blue 30x20.
			widget = {
				position = { 20 320 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						size = { 60 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 40 60 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 30 20 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
				}
			}
			text_single = {
				position = { 20 300 }
				raw_text = "E1: hbox"
			}

			widget = {
				position = { 220 320 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					spacing = 8
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						size = { 60 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 40 60 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 30 20 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
				}
			}
			text_single = {
				position = { 220 300 }
				raw_text = "E2: spacing 8"
			}

			widget = {
				position = { 420 320 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					margin = { 12 6 }
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						size = { 60 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 40 60 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 30 20 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
				}
			}
			text_single = {
				position = { 420 300 }
				raw_text = "E3: margin 12 6"
			}

			# ---- CASE F: vbox metrics ----
			widget = {
				position = { 640 320 }
				size = { 140 160 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				vbox = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.1 0.4 1 }
					}
					icon = {
						size = { 60 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 40 60 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 30 20 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
				}
			}
			text_single = {
				position = { 640 300 }
				raw_text = "F1: vbox"
			}

			widget = {
				position = { 795 320 }
				size = { 140 160 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				vbox = {
					spacing = 8
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.1 0.4 1 }
					}
					icon = {
						size = { 60 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 40 60 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 30 20 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
				}
			}
			text_single = {
				position = { 795 300 }
				raw_text = "F2: spacing 8"
			}

			# ---- CASE G: first text metrics (bg rect = text bounds) ----
			text_single = {
				position = { 20 530 }
				raw_text = "MMMMMMMMMM"
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.5 0 0.5 1 }
				}
			}
			text_single = {
				position = { 20 560 }
				raw_text = "iiiiiiiiii"
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0 0.4 0.4 1 }
				}
			}
			text_single = {
				position = { 20 505 }
				raw_text = "G: 10xM / 10xi"
			}

			# ---- CASE H: nested offset accumulation sanity check ----
			widget = {
				position = { 300 530 }
				size = { 200 110 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.25 0.25 0.25 1 }
				}

				widget = {
					position = { 30 20 }
					size = { 100 60 }
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.5 0.5 0.5 1 }
					}

					icon = {
						position = { 10 10 }
						size = { 20 20 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
				}
			}
			text_single = {
				position = { 300 505 }
				raw_text = "H: nesting"
			}
		}
	}
}
