# CALIBRATION BATCH 02 — box sizing rules, layout policies, flowcontainer, text padding, alpha
# Spawn:   gui.CreateWidget gui/debug/test_gui.gui test_window
# Despawn: gui.clearwidgets test_window
window = {
	name = "test_window"
	parentanchor = center
	size = { 1000 800 }
	layer = top
	filter_mouse = all
	alwaystransparent = no

	using = Window_Background
	using = Window_Decoration
	using = Window_Movable

	vbox = {
		using = Window_Margins

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				raw_text = "Calibration batch 02"
			}

			blockoverride "button_close"
			{
				onclick = "[ExecuteConsoleCommand( 'gui.clearwidgets test_window')]"
			}
		}

		widget = {
			size = { 940 650 }
			background = {
				texture = "gfx/interface/colors/white.dds"
				color = { 0 0 0 1 }
			}

			# ---- ruler (same as batch 01, defines scale + origin) ----
			icon = {
				position = { 20 12 }
				size = { 200 12 }
				texture = "gfx/interface/colors/white.dds"
				color = { 1 1 1 1 }
			}
			icon = {
				position = { 240 12 }
				size = { 100 12 }
				texture = "gfx/interface/colors/white.dds"
				color = { 1 0 1 1 }
			}

			# ---- I1: explicit size on an hbox inside a 180x120 widget ----
			text_single = {
				position = { 20 32 }
				raw_text = "I1: hbox size 150x80"
			}
			widget = {
				position = { 20 60 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					size = { 150 80 }
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
				}
			}

			# ---- I2: hbox nested inside a vbox (does the inner box hug?) ----
			text_single = {
				position = { 220 32 }
				raw_text = "I2: hbox in vbox"
			}
			widget = {
				position = { 220 60 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				vbox = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.1 0.4 1 }
					}
					hbox = {
						background = {
							texture = "gfx/interface/colors/white.dds"
							color = { 0.4 0.1 0.1 1 }
						}
						icon = {
							size = { 40 40 }
							texture = "gfx/interface/colors/white.dds"
							color = { 1 0 0 1 }
						}
						icon = {
							size = { 40 40 }
							texture = "gfx/interface/colors/white.dds"
							color = { 0 1 0 1 }
						}
					}
				}
			}

			# ---- I3: position on a stretched hbox ----
			text_single = {
				position = { 420 32 }
				raw_text = "I3: hbox pos 10 10"
			}
			widget = {
				position = { 420 60 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					position = { 10 10 }
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
				}
			}

			# ---- I4: container hugging absolutely-positioned children ----
			text_single = {
				position = { 620 32 }
				raw_text = "I4: container"
			}
			widget = {
				position = { 620 60 }
				size = { 180 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				container = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.25 0.1 1 }
					}
					icon = {
						position = { 10 10 }
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						position = { 70 30 }
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
				}
			}

			# ---- J1: fixed vs expanding vs growing (300x80 box) ----
			text_single = {
				position = { 20 202 }
				raw_text = "J1: fixed / expanding / growing"
			}
			widget = {
				position = { 20 230 }
				size = { 300 80 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						layoutpolicy_horizontal = expanding
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						layoutpolicy_horizontal = growing
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
				}
			}

			# ---- J2: two expanding children (300x80 box) ----
			text_single = {
				position = { 340 202 }
				raw_text = "J2: expanding x2"
			}
			widget = {
				position = { 340 230 }
				size = { 300 80 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						layoutpolicy_horizontal = expanding
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						layoutpolicy_horizontal = expanding
						size = { 40 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
				}
			}

			# ---- J3: preferred vs shrinking under deficit (120x80 box, content 160) ----
			text_single = {
				position = { 660 202 }
				raw_text = "J3: preferred / shrinking"
			}
			widget = {
				position = { 660 230 }
				size = { 120 80 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				hbox = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.4 0.1 0.1 1 }
					}
					icon = {
						layoutpolicy_horizontal = preferred
						size = { 80 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						layoutpolicy_horizontal = shrinking
						size = { 80 40 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
				}
			}

			# ---- K1: flowcontainer, five 50x30 children in a 200x120 widget ----
			text_single = {
				position = { 20 332 }
				raw_text = "K1: flowcontainer"
			}
			widget = {
				position = { 20 360 }
				size = { 200 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				flowcontainer = {
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.1 0.4 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 1 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 1 1 }
					}
				}
			}

			# ---- K2: flowcontainer direction = vertical ----
			text_single = {
				position = { 240 332 }
				raw_text = "K2: vertical"
			}
			widget = {
				position = { 240 360 }
				size = { 200 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				flowcontainer = {
					direction = vertical
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.1 0.4 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 1 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 1 1 }
					}
				}
			}

			# ---- K3: flowcontainer spacing = 10 ----
			text_single = {
				position = { 460 332 }
				raw_text = "K3: spacing 10"
			}
			widget = {
				position = { 460 360 }
				size = { 200 120 }
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.15 0.15 0.15 1 }
				}

				flowcontainer = {
					spacing = 10
					background = {
						texture = "gfx/interface/colors/white.dds"
						color = { 0.1 0.1 0.4 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 0 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 0 1 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 1 1 0 1 }
					}
					icon = {
						size = { 50 30 }
						texture = "gfx/interface/colors/white.dds"
						color = { 0 1 1 1 }
					}
				}
			}

			# ---- L: text padding (1 vs 2 chars) and multiline wrap ----
			text_single = {
				position = { 20 502 }
				raw_text = "L: M / MM / multi 120"
			}
			text_single = {
				position = { 20 530 }
				raw_text = "M"
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.5 0 0.5 1 }
				}
			}
			text_single = {
				position = { 80 530 }
				raw_text = "MM"
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0 0.4 0.4 1 }
				}
			}
			text_multi = {
				position = { 200 530 }
				max_width = 120
				raw_text = "MMMM MMMM MMMM MMMM"
				background = {
					texture = "gfx/interface/colors/white.dds"
					color = { 0.5 0 0.5 1 }
				}
			}

			# ---- N: alpha blending model (over pure black) ----
			text_single = {
				position = { 420 502 }
				raw_text = "N: color-a 0.5 / alpha 0.5"
			}
			icon = {
				position = { 420 530 }
				size = { 40 40 }
				texture = "gfx/interface/colors/white.dds"
				color = { 1 0 0 0.5 }
			}
			icon = {
				position = { 480 530 }
				size = { 40 40 }
				texture = "gfx/interface/colors/white.dds"
				color = { 1 0 0 1 }
				alpha = 0.5
			}
		}
	}
}
