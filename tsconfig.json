{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "vscode"],
    "paths": {
      "@paradox-lsp/protocol/*": ["packages/protocol/src/*"],
      "@paradox-lsp/server/dds": ["packages/server/src/dds/index.ts"],
      "@paradox-lsp/server/parser": ["packages/server/src/parser/index.ts"],
      "@paradox-lsp/server/*": ["packages/server/src/*"]
    }
  },
  "include": [
    "packages/protocol/src",
    "packages/protocol/test",
    "packages/server/src",
    "packages/server/test",
    "packages/vscode/src",
    "packages/vscode/test",
    "scripts"
  ]
}
